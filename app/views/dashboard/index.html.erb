<!-- Welcome Section -->
<div class="mb-8">
  <h2 class="text-3xl font-bold text-gray-900 mb-2">Welcome back, <%= @user.first_name %>!</h2>
  <p class="text-gray-600">Here's what's happening with your finances today.</p>
</div>

<!-- Key Metrics Cards -->
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
  <!-- Credit Score Card -->
  <div class="bg-white rounded-xl shadow-sm p-6 border border-gray-100 transition-all duration-300 hover:transform hover:-translate-y-1 hover:shadow-lg">
    <div class="flex items-center justify-between mb-4">
      <div class="w-12 h-12 bg-blue-100 rounded-lg flex items-center justify-center">
        <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
        </svg>
      </div>
      <span class="text-sm font-medium 
        <%= case @credit_score
            when 750..Float::INFINITY then "text-green-600 bg-green-100"
            when 700..749 then "text-blue-600 bg-blue-100" 
            when 650..699 then "text-yellow-600 bg-yellow-100"
            when 600..649 then "text-orange-600 bg-orange-100"
            else "text-red-600 bg-red-100"
            end %> px-2 py-1 rounded-full">
        <%= case @credit_score
            when 750..Float::INFINITY then "Excellent"
            when 700..749 then "Very Good" 
            when 650..699 then "Good"
            when 600..649 then "Fair"
            when 550..599 then "Poor"
            else "Very Poor"
            end %>
      </span>
    </div>
    <h3 class="text-sm font-medium text-gray-600 mb-1">Credit Score</h3>
    <p class="text-3xl font-bold text-gray-900"><%= @credit_score %></p>
    <p class="text-sm text-green-600 mt-2">↗ +12 this month</p>
  </div>

  <!-- Available Credit Card -->
  <div class="bg-white rounded-xl shadow-sm p-6 border border-gray-100 transition-all duration-300 hover:transform hover:-translate-y-1 hover:shadow-lg">
    <div class="flex items-center justify-between mb-4">
      <div class="w-12 h-12 bg-green-100 rounded-lg flex items-center justify-center">
        <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1"></path>
        </svg>
      </div>
    </div>
    <h3 class="text-sm font-medium text-gray-600 mb-1">Available Credit</h3>
    <p class="text-3xl font-bold text-gray-900">₱<%= number_with_delimiter(@available_credit.to_i) %></p>
    <p class="text-sm text-gray-500 mt-2">Ready to borrow</p>
  </div>

  <!-- Total Outstanding Card -->
  <div class="bg-white rounded-xl shadow-sm p-6 border border-gray-100 transition-all duration-300 hover:transform hover:-translate-y-1 hover:shadow-lg">
    <div class="flex items-center justify-between mb-4">
      <div class="w-12 h-12 bg-orange-100 rounded-lg flex items-center justify-center">
        <svg class="w-6 h-6 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 17h8m0 0V9m0 8l-8-8-4 4-6-6"></path>
        </svg>
      </div>
    </div>
    <h3 class="text-sm font-medium text-gray-600 mb-1">Total Outstanding</h3>
    <p class="text-3xl font-bold text-gray-900">₱<%= number_with_delimiter(@total_outstanding.to_i) %></p>
    <p class="text-sm text-gray-500 mt-2">Across <%= @stats[:loans_count] %> loans</p>
  </div>

  <!-- Next Payment Card -->
  <div class="bg-white rounded-xl shadow-sm p-6 border border-gray-100 transition-all duration-300 hover:transform hover:-translate-y-1 hover:shadow-lg">
    <div class="flex items-center justify-between mb-4">
      <div class="w-12 h-12 bg-purple-100 rounded-lg flex items-center justify-center">
        <svg class="w-6 h-6 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
        </svg>
      </div>
      <% if @stats[:next_due_date] && @stats[:next_due_date] <= Date.current + 7.days %>
        <span class="text-sm font-medium text-orange-600 bg-orange-100 px-2 py-1 rounded-full">Due Soon</span>
      <% end %>
    </div>
    <h3 class="text-sm font-medium text-gray-600 mb-1">Next Payment</h3>
    <% if @stats[:next_due_date] %>
      <p class="text-3xl font-bold text-gray-900">₱<%= number_with_delimiter(@stats[:next_payment_amount].to_i) %></p>
      <p class="text-sm text-gray-500 mt-2">Due <%= @stats[:next_due_date].strftime("%b %d, %Y") %></p>
    <% else %>
      <p class="text-3xl font-bold text-gray-900">₱0</p>
      <p class="text-sm text-gray-500 mt-2">No payments due</p>
    <% end %>
  </div>
</div>

<!-- Main Content Grid -->
<div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
  <!-- Left Column - Active Loans & Recent Activity -->
  <div class="lg:col-span-2 space-y-8">
    <!-- Active Loans -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100">
      <div class="p-6 border-b border-gray-200">
        <div class="flex items-center justify-between">
          <h3 class="text-lg font-semibold text-gray-900">Active Loans</h3>
          <%= link_to loans_path, class: "text-blue-600 hover:text-blue-700 text-sm font-medium" do %>
            View All
          <% end %>
        </div>
      </div>
      <% if @active_loans.any? %>
        <div class="overflow-x-auto">
          <table class="min-w-full">
            <thead class="bg-gray-50">
              <tr>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Loan</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Amount</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Due Date</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Progress</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Action</th>
              </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200">
              <% @active_loans.each_with_index do |loan, index| %>
                <tr class="hover:bg-gray-50">
                  <td class="px-6 py-4">
                    <div class="flex items-center">
                      <div class="w-10 h-10 <%= index.even? ? 'bg-blue-100' : 'bg-green-100' %> rounded-lg flex items-center justify-center mr-3">
                        <span class="<%= index.even? ? 'text-blue-600' : 'text-green-600' %> font-semibold text-sm">#<%= loan.id %></span>
                      </div>
                      <div>
                        <div class="text-sm font-medium text-gray-900"><%= loan.loan_type.humanize %></div>
                        <div class="text-sm text-gray-500">
                          <% if loan.term_days %>
                            <% if loan.term_days % 30 == 0 %>
                              <%= "#{loan.term_days / 30}-month term" %>
                            <% else %>
                              <%= "#{loan.term_days}-day term" %>
                            <% end %>
                          <% else %>
                            <span class="text-gray-400">Term not specified</span>
                          <% end %>
                        </div>
                      </div>
                    </div>
                  </td>
                  <td class="px-6 py-4 text-sm text-gray-900">₱<%= number_with_delimiter(loan.amount.to_i) %></td>
                  <td class="px-6 py-4 text-sm text-gray-900">
                    <div><%= loan.due_date.strftime("%b %d, %Y") %></div>
                    <% if loan.due_date < Date.current %>
                      <span class="text-red-600 text-xs">Overdue</span>
                    <% elsif loan.due_date <= Date.current + 7.days %>
                      <span class="text-orange-600 text-xs">Due soon</span>
                    <% else %>
                      <span class="text-green-600 text-xs"><%= distance_of_time_in_words(Date.current, loan.due_date) %> left</span>
                    <% end %>
                  </td>
                  <td class="px-6 py-4">
                    <% progress = ((loan.amount - loan.remaining_balance) / loan.amount * 100).round %>
                    <div class="flex items-center">
                      <div class="w-full bg-gray-200 rounded-full h-2 mr-2">
                        <div class="<%= progress >= 80 ? 'bg-green-600' : progress >= 60 ? 'bg-blue-600' : 'bg-orange-600' %> h-2 rounded-full" style="width: <%= progress %>%"></div>
                      </div>
                      <span class="text-xs text-gray-600"><%= progress %>%</span>
                    </div>
                    <div class="text-xs text-gray-500 mt-1">₱<%= number_with_delimiter(loan.remaining_balance.to_i) %> remaining</div>
                  </td>
                  <td class="px-6 py-4">
                    <% if loan.disbursed? %>
                      <%= link_to new_loan_payment_path(loan), class: "bg-blue-600 text-white px-4 py-2 rounded-lg text-sm hover:bg-blue-700 transition-colors" do %>
                        Pay Now
                      <% end %>
                    <% else %>
                      <%= link_to loan_path(loan), class: "bg-gray-100 text-gray-700 px-4 py-2 rounded-lg text-sm hover:bg-gray-200 transition-colors" do %>
                        View Details
                      <% end %>
                    <% end %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div class="p-12 text-center">
          <div class="w-16 h-16 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
            </svg>
          </div>
          <h4 class="text-lg font-medium text-gray-900 mb-2">No Active Loans</h4>
          <p class="text-gray-500 mb-6">You don't have any active loans at the moment.</p>
          <%= link_to new_loan_path, class: "bg-blue-600 text-white px-6 py-2 rounded-lg hover:bg-blue-700 transition-colors" do %>
            Apply for Your First Loan
          <% end %>
        </div>
      <% end %>
    </div>

    <!-- Recent Payments -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100">
      <div class="p-6 border-b border-gray-200">
        <h3 class="text-lg font-semibold text-gray-900">Recent Payments</h3>
      </div>
      <% if @recent_payments.any? %>
        <div class="p-6">
          <div class="space-y-4">
            <% @recent_payments.each do |payment| %>
              <div class="flex items-center justify-between py-3 border-b border-gray-100 last:border-b-0">
                <div class="flex items-center">
                  <div class="w-10 h-10 <%= payment.status == 'completed' ? 'bg-green-100' : payment.status == 'processing' ? 'bg-blue-100' : 'bg-gray-100' %> rounded-full flex items-center justify-center mr-3">
                    <% if payment.status == 'completed' %>
                      <svg class="w-5 h-5 text-green-600" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                      </svg>
                    <% elsif payment.status == 'processing' %>
                      <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                      </svg>
                    <% else %>
                      <svg class="w-5 h-5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1"></path>
                      </svg>
                    <% end %>
                  </div>
                  <div>
                    <div class="text-sm font-medium text-gray-900">Loan #<%= payment.loan_id %> Payment</div>
                    <div class="text-sm text-gray-500"><%= (payment.paid_at || payment.created_at).strftime("%b %d, %Y") %></div>
                  </div>
                </div>
                <div class="text-right">
                  <div class="text-sm font-medium text-gray-900">₱<%= number_with_delimiter(payment.amount.to_i) %></div>
                  <div class="text-sm 
                    <%= case payment.status
                        when 'completed' then 'text-green-600'
                        when 'pending' then 'text-yellow-600'
                        when 'processing' then 'text-blue-600'
                        when 'failed' then 'text-red-600'
                        else 'text-gray-600'
                        end %>">
                    <%= payment.status.humanize %>
                  </div>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      <% else %>
        <div class="p-12 text-center">
          <div class="w-16 h-16 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1"></path>
            </svg>
          </div>
          <h4 class="text-lg font-medium text-gray-900 mb-2">No Recent Payments</h4>
          <p class="text-gray-500">Your payment history will appear here once you start making payments.</p>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Right Column - Quick Actions & Stats -->
  <div class="space-y-8">
    <!-- Quick Actions -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100">
      <div class="p-6 border-b border-gray-200">
        <h3 class="text-lg font-semibold text-gray-900">Quick Actions</h3>
      </div>
      <div class="p-6 space-y-4">
        <%= link_to new_loan_path, class: "w-full bg-blue-600 text-white py-3 px-4 rounded-lg hover:bg-blue-700 transition-colors flex items-center justify-center space-x-2" do %>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
          </svg>
          <span>Apply for New Loan</span>
        <% end %>
        <%= link_to loans_path, class: "w-full bg-gray-100 text-gray-700 py-3 px-4 rounded-lg hover:bg-gray-200 transition-colors flex items-center justify-center space-x-2" do %>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
          </svg>
          <span>View All Loans</span>
        <% end %>
        <% if @active_loans.any? %>
          <%= link_to loan_payments_path(@priority_loan || @active_loans.min_by(&:due_date)), class: "w-full bg-gray-100 text-gray-700 py-3 px-4 rounded-lg hover:bg-gray-200 transition-colors flex items-center justify-center space-x-2" do %>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1"></path>
            </svg>
            <span>View Payments</span>
          <% end %>
        <% else %>
          <button class="w-full bg-gray-100 text-gray-700 py-3 px-4 rounded-lg hover:bg-gray-200 transition-colors flex items-center justify-center space-x-2" disabled>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1"></path>
            </svg>
            <span>No Active Loans</span>
          </button>
        <% end %>
        <button class="w-full bg-gray-100 text-gray-700 py-3 px-4 rounded-lg hover:bg-gray-200 transition-colors flex items-center justify-center space-x-2">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2-2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
          </svg>
          <span>View Credit Report</span>
        </button>
      </div>
    </div>

    <!-- Financial Health -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100">
      <div class="p-6 border-b border-gray-200">
        <h3 class="text-lg font-semibold text-gray-900">Financial Health</h3>
      </div>
      <div class="p-6 space-y-6">
        <div>
          <div class="flex justify-between items-center mb-2">
            <span class="text-sm font-medium text-gray-700">Payment History</span>
            <span class="text-sm font-bold text-green-600"><%= @stats[:on_time_payments] %>%</span>
          </div>
          <div class="w-full bg-gray-200 rounded-full h-2">
            <div class="bg-green-500 h-2 rounded-full" style="width: <%= @stats[:on_time_payments] %>%"></div>
          </div>
          <p class="text-xs text-gray-500 mt-1">
            <%= @stats[:on_time_payments] >= 95 ? "Excellent" : @stats[:on_time_payments] >= 80 ? "Good" : "Needs improvement" %> payment record
          </p>
        </div>
        
        <div>
          <div class="flex justify-between items-center mb-2">
            <span class="text-sm font-medium text-gray-700">Credit Utilization</span>
            <% utilization = @available_credit > 0 ? ((@total_outstanding / @available_credit) * 100).round : 0 %>
            <span class="text-sm font-bold text-blue-600"><%= utilization %>%</span>
          </div>
          <div class="w-full bg-gray-200 rounded-full h-2">
            <div class="bg-blue-500 h-2 rounded-full" style="width: <%= utilization %>%"></div>
          </div>
          <p class="text-xs text-gray-500 mt-1">Using ₱<%= number_with_delimiter(@total_outstanding.to_i) %> of ₱<%= number_with_delimiter(@available_credit.to_i) %> limit</p>
        </div>

        <div class="bg-blue-50 p-4 rounded-lg">
          <div class="flex items-center mb-2">
            <svg class="w-5 h-5 text-blue-600 mr-2" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"></path>
            </svg>
            <h4 class="text-sm font-medium text-blue-900">Tip</h4>
          </div>
          <p class="text-sm text-blue-800">Consider making an early payment to improve your credit utilization ratio.</p>
        </div>
      </div>
    </div>

    <!-- Achievements -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100">
      <div class="p-6 border-b border-gray-200">
        <h3 class="text-lg font-semibold text-gray-900">Recent Achievements</h3>
      </div>
      <div class="p-6 space-y-4">
        <% if @stats[:on_time_payments] >= 95 %>
        <div class="flex items-center space-x-3">
          <div class="w-10 h-10 bg-yellow-100 rounded-full flex items-center justify-center">
            <svg class="w-5 h-5 text-yellow-600" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path>
            </svg>
          </div>
          <div>
            <div class="text-sm font-medium text-gray-900">Perfect Payment Streak</div>
            <div class="text-xs text-gray-500">Excellent payment history</div>
          </div>
        </div>
        <% end %>
        <div class="flex items-center space-x-3">
          <div class="w-10 h-10 bg-green-100 rounded-full flex items-center justify-center">
            <svg class="w-5 h-5 text-green-600" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
            </svg>
          </div>
          <div>
            <div class="text-sm font-medium text-gray-900">Active Member</div>
            <div class="text-xs text-gray-500">Using ELMO services</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
