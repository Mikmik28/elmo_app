<!-- Financial Health -->
<div class="bg-white rounded-xl shadow-sm border border-gray-100">
  <div class="p-6 border-b border-gray-200">
    <h3 class="text-lg font-semibold text-gray-900">Financial Health</h3>
  </div>
  <div class="p-6 space-y-6">
    <div>
      <div class="flex justify-between items-center mb-2">
        <span class="text-sm font-medium text-gray-700">Payment History</span>
        <span class="text-sm font-bold text-green-600"><%= stats[:on_time_payments] %>%</span>
      </div>
      <div class="w-full bg-gray-200 rounded-full h-2">
        <div class="bg-green-500 h-2 rounded-full" style="width: <%= stats[:on_time_payments] %>%"></div>
      </div>
      <p class="text-xs text-gray-500 mt-1">
        <%= stats[:on_time_payments] >= 95 ? "Excellent" : stats[:on_time_payments] >= 80 ? "Good" : "Needs improvement" %> payment record
      </p>
    </div>
    
    <div>
      <div class="flex justify-between items-center mb-2">
        <span class="text-sm font-medium text-gray-700">Credit Utilization</span>
        <% utilization = available_credit.to_f > 0 ? ((total_outstanding.to_f / available_credit.to_f) * 100).round : 0 %>
        <span class="text-sm font-bold text-blue-600"><%= utilization %>%</span>
      </div>
      <div class="w-full bg-gray-200 rounded-full h-2">
        <div class="bg-blue-500 h-2 rounded-full" style="width: <%= utilization %>%"></div>
      </div>
      <p class="text-xs text-gray-500 mt-1">Using ₱<%= number_with_delimiter(total_outstanding.to_i) %> of ₱<%= number_with_delimiter(available_credit.to_i) %> limit</p>
    </div>

    <div class="bg-blue-50 p-4 rounded-lg">
      <div class="flex items-center mb-2">
        <svg class="w-5 h-5 text-blue-600 mr-2" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"></path>
        </svg>
        <h4 class="text-sm font-medium text-blue-900">Tip</h4>
      </div>
      <p class="text-sm text-blue-800">Consider making an early payment to improve your credit utilization ratio.</p>
    </div>
  </div>
</div>
