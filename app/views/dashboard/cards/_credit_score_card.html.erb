<!-- Credit Score Card -->
<div class="bg-white rounded-xl shadow-sm p-6 border border-gray-100 transition-all duration-300 hover:transform hover:-translate-y-1 hover:shadow-lg">
  <div class="flex items-center justify-between mb-4">
    <div class="w-12 h-12 bg-blue-100 rounded-lg flex items-center justify-center">
      <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
      </svg>
    </div>
    <span class="text-sm font-medium 
      <%= case credit_score
          when 750..Float::INFINITY then "text-green-600 bg-green-100"
          when 700..749 then "text-blue-600 bg-blue-100" 
          when 650..699 then "text-yellow-600 bg-yellow-100"
          when 600..649 then "text-orange-600 bg-orange-100"
          else "text-red-600 bg-red-100"
          end %> px-2 py-1 rounded-full">
      <%= case credit_score
          when 750..Float::INFINITY then "Excellent"
          when 700..749 then "Very Good" 
          when 650..699 then "Good"
          when 600..649 then "Fair"
          when 550..599 then "Poor"
          else "Very Poor"
          end %>
    </span>
  </div>
  <h3 class="text-sm font-medium text-gray-600 mb-1">Credit Score</h3>
  <p class="text-3xl font-bold text-gray-900"><%= credit_score %></p>
  <p class="text-sm <%= stats[:credit_score_change] >= 0 ? 'text-green-600' : 'text-red-600' %> mt-2">
    <% if stats[:credit_score_change].present? %>
      <%= stats[:credit_score_change] > 0 ? "↗ +#{stats[:credit_score_change]}" : "↘ #{stats[:credit_score_change]}" %> this month
    <% else %>
      <span class="text-gray-400">No data for this month</span>
    <% end %>
  </p>
</div>
