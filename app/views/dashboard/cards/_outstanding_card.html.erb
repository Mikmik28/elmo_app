<!-- Total Outstanding Card -->
<div class="bg-white rounded-xl shadow-sm p-6 border border-gray-100 transition-all duration-300 hover:transform hover:-translate-y-1 hover:shadow-lg">
  <div class="flex items-center justify-between mb-4">
    <div class="w-12 h-12 bg-orange-100 rounded-lg flex items-center justify-center">
      <svg class="w-6 h-6 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 17h8m0 0V9m0 8l-8-8-4 4-6-6"></path>
      </svg>
    </div>
  </div>
  <h3 class="text-sm font-medium text-gray-600 mb-1">Total Outstanding</h3>
  <p class="text-3xl font-bold text-gray-900">₱<%= number_with_delimiter(total_outstanding.to_i) %></p>
  <p class="text-sm text-gray-500 mt-2">Across <%= stats[:loans_count] %> loans</p>
</div>
