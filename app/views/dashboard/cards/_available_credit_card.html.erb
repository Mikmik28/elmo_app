<!-- Available Credit Card -->
<div class="bg-white rounded-xl shadow-sm p-6 border border-gray-100 transition-all duration-300 hover:transform hover:-translate-y-1 hover:shadow-lg">
  <div class="flex items-center justify-between mb-4">
    <div class="w-12 h-12 bg-green-100 rounded-lg flex items-center justify-center">
      <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1"></path>
      </svg>
    </div>
  </div>
  <h3 class="text-sm font-medium text-gray-600 mb-1">Available Credit</h3>
  <p class="text-3xl font-bold text-gray-900">₱<%= number_with_delimiter(available_credit.to_i) %></p>
  <p class="text-sm text-gray-500 mt-2">Ready to borrow</p>
</div>
